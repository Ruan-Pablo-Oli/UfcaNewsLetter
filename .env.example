# Copie este arquivo para ".env" e ajuste os valores conforme o ambiente.
# NUNCA versione o arquivo ".env" (ele já está no .gitignore).

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# PostgreSQL
POSTGRES_DB=ufcanewsletter
POSTGRES_USER=ufcanewsletter
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
